# -*- mode: ruby -*-
# vi: set ft=ruby :

# Supported OS configurations
# Set BOX_NAME environment variable to choose OS
# Examples:
#   BOX_NAME=ubuntu2204 vagrant up
#   BOX_NAME=ubuntu2404 vagrant up
#   BOX_NAME=debian12 vagrant up
#   BOX_NAME=macos15 vagrant up

require 'securerandom'


def random_string(length = 8)
  return SecureRandom.alphanumeric(length).downcase
end

BOX_CONFIGS = {
  # Ubuntu versions
  "ubuntu2404" => {
    box: "onlyoffice/base-ubuntu2404",
    name: "Ubuntu 24.04 LTS",
    memory: 4096,
    cpus: 2,
    os_family: "linux"
  },
}

# Get box name from environment variable or use default
box_name = ENV['BOX_NAME'] || ENV['VAGRANT_BOX'] || 'ubuntu2404'

# Validate box name
unless BOX_CONFIGS.key?(box_name)
  puts "Error: Unknown box name '#{box_name}'"
  puts "Available boxes:"
  BOX_CONFIGS.each do |key, config|
    puts "  - #{key}: #{config[:name]}"
  end
  puts "\nUsage: BOX_NAME=ubuntu2404 vagrant up"
  exit 1
end

# Get configuration for selected box
box_config = BOX_CONFIGS[box_name]

puts "=" * 50
puts "Using: #{box_config[:name]}"
puts "Box: #{box_config[:box]}"
puts "=" * 50

Vagrant.configure("2") do |config|

  # Generate UUID for hostname
  uuid = random_string(8)
  # Use selected box
  config.vm.box = box_config[:box]
  config.vm.hostname = "diffusion-e2e-#{box_name}-#{uuid}"

  # Configure VM resources
  config.vm.provider "virtualbox" do |vb|
    vb.memory = box_config[:memory]
    vb.cpus = box_config[:cpus]
    vb.name = "diffusion-e2e-#{box_name}-#{uuid}"
  end

  config.vm.provider "vmware_desktop" do |vmware|
    vmware.vmx["memsize"] = box_config[:memory].to_s
    vmware.vmx["numvcpus"] = box_config[:cpus].to_s
    vmware.gui = false
  end

  # libvirt provider for GitHub Actions CI (KVM-based)
  config.vm.provider "libvirt" do |lv|
    lv.memory = box_config[:memory]
    lv.cpus = box_config[:cpus]
  end

  # Hyper-V provider for Windows hosts with Core Isolation enabled.
  # Core Isolation requires Hyper-V, which degrades VirtualBox/VMware performance
  # (they fall back to Hyper-V passthrough / WHP mode instead of native hardware access).
  # Using the Hyper-V provider directly gives the best performance on such hosts.
  # Nested virtualization is enabled so Windows guests can run WSL2 + Docker.
  # NOTE: Vagrant with Hyper-V must be run from an elevated (Administrator) shell.
  config.vm.provider "hyperv" do |h|
    h.vmname = "diffusion-e2e-#{box_name}"
    h.cpus = box_config[:cpus]
    h.memory = box_config[:memory]
    h.maxmemory = nil                          # Disable dynamic memory (required for nested virt)
    h.enable_virtualization_extensions = true   # Nested Hyper-V for WSL2/Docker in Windows guests
    h.enable_checkpoints = false               # Disable checkpoints for performance
  end

  # Sync diffusion source code to VM
  # Path differs by OS family. Hyper-V uses SMB by default which
  # requires the host to be accessible over the network.
  if box_config[:os_family] == "windows"
    config.vm.synced_folder "../../", "C:/diffusion"
  elsif box_config[:os_family] == "macos"
    config.vm.synced_folder "../../", "/Users/vagrant/diffusion"
  else
    config.vm.synced_folder "../../", "/home/vagrant/diffusion"
  end

  # OS-specific provisioning
  if box_config[:os_family] == "linux"
    # Linux provisioning (Ubuntu/Debian)
    config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "=========================================="
    echo "Installing system dependencies..."
    echo "=========================================="

    # Update package list
    apt-get update

    # Install basic tools
    apt-get install -y \
      curl \
      wget \
      git \
      build-essential \
      ca-certificates \
      gnupg \
      lsb-release

    echo "=========================================="
    echo "Installing Docker..."
    echo "=========================================="

    # Add Docker's official GPG key
    install -m 0755 -d /etc/apt/keyrings

    # Detect distro for correct Docker repository
    DISTRO_ID=$(. /etc/os-release && echo "$ID")
    if [ "$DISTRO_ID" = "debian" ]; then
      DOCKER_REPO_URL="https://download.docker.com/linux/debian"
    else
      DOCKER_REPO_URL="https://download.docker.com/linux/ubuntu"
    fi

    [ -f "/etc/apt/keyrings/docker.gpg" ] || curl -fsSL "${DOCKER_REPO_URL}/gpg" | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    [ -f "/etc/apt/keyrings/docker.gpg" ] || chmod a+r /etc/apt/keyrings/docker.gpg

    # Add Docker repository (using detected distro)
    echo \
      "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] ${DOCKER_REPO_URL} \
      $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null

    # Install Docker
    apt-get update
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    # Add vagrant user to docker group
    usermod -aG docker vagrant

    # Start and enable Docker
    systemctl start docker
    systemctl enable docker

    echo "=========================================="
    echo "Installing Go 1.25..."
    echo "=========================================="

    # Download and install Go (must match go.mod version)
    GO_VERSION="1.25.4"
    wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz
    rm -rf /usr/local/go
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz
    rm go${GO_VERSION}.linux-amd64.tar.gz

    # Set up Go environment for all users
    echo 'export PATH=$PATH:/usr/local/go/bin' >> /etc/profile.d/go.sh
    echo 'export GOPATH=$HOME/go' >> /etc/profile.d/go.sh
    echo 'export PATH=$PATH:$GOPATH/bin' >> /etc/profile.d/go.sh

    # Set up for vagrant user
    echo 'export PATH=$PATH:/usr/local/go/bin' >> /home/vagrant/.bashrc
    echo 'export GOPATH=$HOME/go' >> /home/vagrant/.bashrc
    echo 'export PATH=$PATH:$GOPATH/bin' >> /home/vagrant/.bashrc

    echo "=========================================="
    echo "Docker and Go installation complete!"
    echo "=========================================="

    # Verify installations
    docker --version
    /usr/local/go/bin/go version

  SHELL

  # Run tests as vagrant user (non-root)
  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    set -e

    echo "=========================================="
    echo "Installing expect..."
    echo "=========================================="

    # Install expect for automated CLI interaction
    sudo apt-get install -y expect

    echo "=========================================="
    echo "Building diffusion..."
    echo "=========================================="

    cd /home/vagrant/diffusion

    # Build diffusion
    make build

    echo "=========================================="
    echo "Running E2E tests..."
    echo "=========================================="

    # Create test directory
    [ -d "/home/vagrant/test" ] && rm -rf "/home/vagrant/test"
    mkdir -p /home/vagrant/test
    cd /home/vagrant/test

    # Test 1: Initialize a new role using expect
    echo "Test 1: Initialize new role..."
    sleep 30
    expect <<'EXPECT_SCRIPT'
set timeout 30
spawn /home/vagrant/diffusion/bin/diffusion role --init
expect "Enter role name:"
send "test_role\r"
expect "What namespace of the role should be?:"
send "testorg\r"
expect "What company of the role should be?:"
send "Test Company\r"
expect "What author of the role should be?:"
send "Test Author\r"
expect "Description of the role (optional):"
send "Test role for E2E testing\r"
expect "Enter platforms? (y/n):"
send "n\r"
expect "Galaxy Tags (comma-separated) (optional):"
send "test1,test2,org\r"
expect "Collections required (comma-separated) (optional):"
send "\r"
expect "Enter roles to add? (y/n):"
send "n\r"
expect eof
EXPECT_SCRIPT

    # Verify meta.yml file was created
    if [ -f "test_role/meta/main.yml" ]; then
      echo "✓ meta.yml creation successful"
    else
      echo "✗ meta.yml creation failed"
      exit 1
    fi

    # Verify meta.yml content: role name
    if grep -q "role_name: test_role" "test_role/meta/main.yml"; then
      echo "✓ meta.yml role name is correct"
    else
      echo "✗ meta.yml role name is missing or incorrect"
      echo "--- meta.yml content ---"
      cat "test_role/meta/main.yml"
      exit 1
    fi

    # Verify meta.yml content: namespace
    if grep -q "namespace: testorg" "test_role/meta/main.yml"; then
      echo "✓ meta.yml namespace is correct"
    else
      echo "✗ meta.yml namespace is missing or incorrect"
      echo "--- meta.yml content ---"
      cat "test_role/meta/main.yml"
      exit 1
    fi

    # Verify meta.yml content: author
    if grep -q "author: Test Author" "test_role/meta/main.yml"; then
      echo "✓ meta.yml author is correct"
    else
      echo "✗ meta.yml author is missing or incorrect"
      echo "--- meta.yml content ---"
      cat "test_role/meta/main.yml"
      exit 1
    fi

    # Verify meta.yml content: description
    if grep -q "description: Test role for E2E testing" "test_role/meta/main.yml"; then
      echo "✓ meta.yml description is correct"
    else
      echo "✗ meta.yml description is missing or incorrect"
      echo "--- meta.yml content ---"
      cat "test_role/meta/main.yml"
      exit 1
    fi

    # Verify meta.yml content: galaxy_tags
    META_FILE="test_role/meta/main.yml"
    TAGS_OK=true
    for tag in test1 test2 org; do
      if grep -q "^\s*- ${tag}$" "$META_FILE"; then
        echo "✓ meta.yml galaxy_tags contains '${tag}'"
      else
        echo "✗ meta.yml galaxy_tags missing '${tag}'"
        TAGS_OK=false
      fi
    done
    if [ "$TAGS_OK" = "false" ]; then
      echo "--- meta.yml content ---"
      cat "$META_FILE"
      exit 1
    fi

    # Verify requirements.yml file was created
    if [ -f "test_role/scenarios/default/requirements.yml" ]; then
      echo "✓ requirements.yml creation successful"
    else
      echo "✗ requirements.yml creation failed"
      exit 1
    fi

    cd test_role
    expect <<'EXPECT_SCRIPT'
set timeout 30
spawn /home/vagrant/diffusion/bin/diffusion molecule
expect "Enter RegistryServer (ghcr.io):"
send "\r"
expect "Enter RegistryProvider (Public):"
send "\r"
expect "Enter MoleculeContainerName*"
send "\r"
expect "Enter MoleculeContainerTag*"
send "\r"
expect "Enable Vault Integration for artifact sources? (y/N):"
send "N\r"
expect "Configure artifact sources for private repositories? (y/N):"
send "N\r"
expect "What type of configuration you want use?*"
send "\r"
expect eof
EXPECT_SCRIPT

    # Verify config was created
    if [ -f "diffusion.toml" ]; then
      echo "✓ Config creation successful"
    else
      echo "✗ Config creation failed"
      exit 1
    fi

    # Test 3: Check molecule directory permissions
    echo "Test 3: Check molecule directory permissions..."
    if [ -d "molecule" ]; then
      OWNER=$(stat -c '%U' molecule)
      if [ "$OWNER" = "vagrant" ]; then
        echo "✓ Molecule directory has correct ownership (vagrant)"
      else
        echo "✗ Molecule directory has wrong ownership ($OWNER, expected vagrant)"
        exit 1
      fi
    else
      echo "✗ Molecule directory not created"
      exit 1
    fi

    # Test 4: Check files in molecule directory
    echo "Test 4: Check files in molecule directory..."
    if [ -d "molecule/myorg.test_role" ]; then
      FILE_OWNER=$(stat -c '%U' molecule/myorg.test_role)
      if [ "$FILE_OWNER" = "vagrant" ]; then
        echo "✓ Files in molecule directory have correct ownership"
      else
        echo "✗ Files have wrong ownership ($FILE_OWNER, expected vagrant)"
        exit 1
      fi
    fi

    # Test 5: Test cache feature
    echo "Test 5: Test cache feature..."
    /home/vagrant/diffusion/bin/diffusion cache enable
    /home/vagrant/diffusion/bin/diffusion cache status

    if [ -d "$HOME/.diffusion/cache" ]; then
      echo "✓ Cache directory created"
    else
      echo "✗ Cache directory not created"
      exit 1
    fi

    # Test 6: Test artifact management
    echo "Test 6: Test artifact management..."
    /home/vagrant/diffusion/bin/diffusion artifact list

    echo "=========================================="
    echo "All E2E tests passed! ✓"
    echo "=========================================="

    # Print summary
    echo ""
    echo "Summary:"
    echo "  - Docker version: $(docker --version)"
    echo "  - Go version: $(/usr/local/go/bin/go version)"
    echo "  - Diffusion built successfully"
    echo "  - All unit tests passed"
    echo "  - All E2E tests passed"
    echo "  - Permissions verified on Unix system"
    echo ""

  SHELL
  end
end
